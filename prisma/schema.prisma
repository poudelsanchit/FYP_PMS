generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  ORG_ADMIN
  ORG_MEMBER
}

enum ProjectRole {
  PROJECT_LEAD
  PROJECT_MEMBER
}

// Project Management Enums
enum BoardType {
  KANBAN
}

enum BoardRole {
  BOARD_LEAD
  BOARD_MEMBER
  BOARD_VIEWER
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  avatar              String?
  isVerified          Boolean              @default(false)
  googleId            String               @unique @map("google_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  organizationMembers OrganizationMember[]
  projects            Project[]
  projectMembers      ProjectMember[]
  projectInvitations  ProjectInvitation[]
  boardMembers        BoardMember[]
  issueAssignees      IssueAssignee[]

  @@map("users")
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, code])
  @@map("otps")
}

model Organization {
  id          String                   @id @default(uuid())
  name        String
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  invitations OrganizationInvitation[]
  members     OrganizationMember[]
  projects    Project[]
  boards      Board[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  userId         String
  role           OrganizationRole @default(ORG_MEMBER)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id             String           @id @default(uuid())
  email          String
  organizationId String
  role           OrganizationRole @default(ORG_MEMBER)
  token          String           @unique @default(uuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([email])
  @@index([token])
}

model Project {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  key            String // Unique within organization, 2-10 alphanumeric chars
  description    String?
  color          String?  @default("#3b82f6") // Hex color code, defaults to blue
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members           ProjectMember[]
  invitations       ProjectInvitation[]
  boards            Board[]
  issues            Issue[]
  projectLabels     ProjectLabel[]
  projectPriorities ProjectPriority[]
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectInvitation {
  id         String      @id @default(uuid())
  userId     String
  role       ProjectRole
  token      String      @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([token])
}

model Board {
  id             String    @id @default(uuid())
  projectId      String
  organizationId String // Denormalized for query efficiency
  name           String
  type           BoardType @default(KANBAN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  columns      Column[]
  labels       Label[]
  priorities   Priority[]
  members      BoardMember[]

  @@index([projectId])
  @@index([organizationId])
}

model BoardMember {
  id       String    @id @default(uuid())
  boardId  String
  userId   String
  role     BoardRole
  joinedAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
}

model Column {
  id        String   @id @default(uuid())
  boardId   String
  name      String
  order     Int // Unique within board for ordering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board  Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@unique([boardId, order])
  @@index([boardId])
}

model Issue {
  id          String   @id @default(uuid())
  projectId   String
  columnId    String
  title       String
  description String
  labelId     String?
  priorityId  String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column    Column          @relation(fields: [columnId], references: [id], onDelete: Restrict)
  label     Label?          @relation(fields: [labelId], references: [id], onDelete: SetNull)
  priority  Priority?       @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  assignees IssueAssignee[]

  @@index([projectId])
  @@index([columnId])
  @@index([labelId])
  @@index([priorityId])
}

model IssueAssignee {
  id         String   @id @default(uuid())
  issueId    String
  userId     String
  assignedAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issueId, userId])
  @@index([issueId])
  @@index([userId])
}

model Label {
  id        String   @id @default(uuid())
  boardId   String
  name      String // Unique within board
  color     String? // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board  Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@unique([boardId, name])
  @@index([boardId])
}

model Priority {
  id        String   @id @default(uuid())
  boardId   String
  name      String // Unique within board
  order     Int // For sorting
  color     String? // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board  Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@unique([boardId, name])
  @@index([boardId])
}

// Project-level Labels and Priorities
model ProjectLabel {
  id        String   @id @default(uuid())
  projectId String
  name      String // Unique within project
  color     String // Hex color code (required for project labels)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectPriority {
  id        String   @id @default(uuid())
  projectId String
  name      String // Unique within project
  order     Int // For sorting
  color     String // Hex color code (required for project priorities)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}
