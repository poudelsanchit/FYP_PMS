generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  ORG_ADMIN
  ORG_MEMBER
}

enum ProjectRole {
  PROJECT_LEAD
  PROJECT_MEMBER
}

enum BoardType {
  KANBAN
}

enum DocStatus {
  DRAFT
  PUBLISHED
}

// ─── Billing ──────────────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
  UNPAID
}

// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  avatar              String?
  isVerified          Boolean              @default(false)
  googleId            String               @unique @map("google_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  organizationMembers OrganizationMember[]
  projects            Project[]
  projectMembers      ProjectMember[]
  projectInvitations  ProjectInvitation[]
  issueAssignees      IssueAssignee[]
  meetingRooms        MeetingRoom[]
  meetingParticipants MeetingParticipant[]
  docs                Doc[]

  @@map("users")
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, code])
  @@map("otps")
}

model Organization {
  id           String                   @id @default(uuid())
  name         String
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  invitations  OrganizationInvitation[]
  members      OrganizationMember[]
  projects     Project[]
  boards       Board[]
  meetingRooms MeetingRoom[]
  subscription OrganizationSubscription? // NEW
}

model OrganizationMember {
  id             String           @id @default(uuid())
  userId         String
  role           OrganizationRole @default(ORG_MEMBER)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id             String           @id @default(uuid())
  email          String
  organizationId String
  role           OrganizationRole @default(ORG_MEMBER)
  token          String           @unique @default(uuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([email])
  @@index([token])
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model OrganizationSubscription {
  id                     String             @id @default(uuid())
  organizationId         String             @unique
  plan                   PlanTier           @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)

  // Stripe identifiers
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?          // when the current billing period ends

  cancelAtPeriodEnd      Boolean            @default(false)
  trialEndsAt            DateTime?

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("organization_subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  key            String
  description    String?
  color          String?  @default("#3b82f6")
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members           ProjectMember[]
  invitations       ProjectInvitation[]
  boards            Board[]
  issues            Issue[]
  projectLabels     ProjectLabel[]
  projectPriorities ProjectPriority[]
  docs              Doc[]
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectInvitation {
  id         String      @id @default(uuid())
  userId     String
  role       ProjectRole
  token      String      @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  projectId  String?

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([token])
}

model Board {
  id             String    @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  type           BoardType @default(KANBAN)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  columns      Column[]

  @@index([projectId])
  @@index([organizationId])
}

model Column {
  id          String   @id @default(uuid())
  boardId     String
  name        String
  order       Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board  Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@unique([boardId, order])
  @@index([boardId])
}

model Issue {
  id          String    @id @default(uuid())
  projectId   String
  columnId    String
  title       String
  description String
  labelId     String?
  priorityId  String?
  dueDate     DateTime?
  completedAt DateTime?
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column    Column           @relation(fields: [columnId], references: [id], onDelete: Restrict)
  label     ProjectLabel?    @relation(fields: [labelId], references: [id], onDelete: SetNull)
  priority  ProjectPriority? @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  assignees IssueAssignee[]

  @@index([projectId])
  @@index([columnId])
  @@index([labelId])
  @@index([priorityId])
}

model IssueAssignee {
  id         String   @id @default(uuid())
  issueId    String
  userId     String
  assignedAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issueId, userId])
  @@index([issueId])
  @@index([userId])
}

model ProjectLabel {
  id        String   @id @default(uuid())
  projectId String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectPriority {
  id        String   @id @default(uuid())
  projectId String
  name      String
  order     Int
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, name])
  @@index([projectId])
}

// ─── Meeting Rooms ────────────────────────────────────────────────────────────

model MeetingRoom {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  description    String?
  password       String
  createdById    String
  isActive       Boolean   @default(true)
  scheduledAt    DateTime?
  endedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]

  @@index([organizationId])
  @@index([createdById])
}

model MeetingParticipant {
  id       String   @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  room MeetingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

// ─── Documentation ────────────────────────────────────────────────────────────

model Doc {
  id        String    @id @default(uuid())
  projectId String
  emoji     String    @default("📝")
  title     String    @default("")
  content   String    @default("{\"type\":\"doc\",\"content\":[]}") @db.Text
  status    DocStatus @default(DRAFT)
  authorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([authorId])
  @@index([status])
  @@map("docs")
}
